# Discord Bot Configuration
# Get your bot token from: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Your Discord server (guild) ID
# Enable Developer Mode in Discord settings, then right-click your server → Copy ID
DISCORD_GUILD_ID=your_server_id_here

# Default channel ID for operations (optional)
DISCORD_DEFAULT_CHANNEL_ID=your_default_channel_id

# API Server Configuration
PORT=3000
NODE_ENV=development

# Authentication Configuration
# Toggle API token authentication on/off from this central point
API_AUTH_ENABLED=true

# Your secure API token (required when API_AUTH_ENABLED=true)
# Generate a secure token using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_TOKEN=your_secure_api_token_here

# Rate Limiting Configuration (Optional)
RATE_LIMIT_WINDOW_MS=60000              # Time window in milliseconds (60000 = 1 minute)
RATE_LIMIT_MAX_REQUESTS=100             # Maximum requests per window

# Logging Configuration
LOG_LEVEL=info                          # Options: debug, info, warn, error

# CORS Configuration (Optional)
CORS_ORIGIN=*                           # Allowed origins (* for all, or specific URLs)

# Application Settings
REQUEST_TIMEOUT=30000                   # Request timeout in milliseconds
MAX_MESSAGE_LENGTH=2000                 # Maximum message content length
DEFAULT_MESSAGE_LIMIT=50                # Default number of messages to retrieve
